import numpy as np
import pandas as pd


s = pd.Series([1,2,3,4,5])
print(s)


#set labelled data 
s = pd.Series([1,2,3,4,5], index=["one","two","three", "four", "five"])
print(s)

# access all index 
print(s.index)

# why index dtype showing as a object in outptu - 
# In pandas (and the underlying NumPy library), there isn't a specific string data type used by default for indexes. 
#Instead, pandas uses the object dtype to store pointers to any non-numeric data, which most commonly includes strings.





# Access the value of series

print(s["one"]) # using index or label
# print(s[0])     # using index/position eg. 0, 1, 2,3







# Homogenous - always store index in object format
print("\n pandas series is  homogenous ")
x = pd.Series([1,2,3,4,5,"abc"], index=["one","two","three", "four", "five",23])
print(x)
print("\n pandas series is  homogenous ")

#vectorized Openration - 
print("\n vectorized operations")
vec_ops = x * 2
print(vec_ops)

# Handle missing value with NaN - see in next lecture

# mutuable values, immutable size
print("\n mutuable values")
x["one"] = 97
print(x)

print("\n immutable size") # using drop function
change_seri = x.drop("one")
print(x)
print(change_seri)









