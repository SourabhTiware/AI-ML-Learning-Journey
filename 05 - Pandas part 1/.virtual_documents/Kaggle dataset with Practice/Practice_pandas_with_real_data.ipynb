


import pandas as pd


ps = pd.Series([1,2,3,4])
print(ps)


df = pd.read_csv("globalAirQuality.csv")
print(df)











# Selecting Data

# Select Columns
df["country"]
df[["city", "aqi"]]


# Select rows (by label)

# df.loc[0]            # 1st row (by lable)
df[0:3]              # row0 to row3 - both inclusive in loc


# Select row (by indexing)
df.iloc[0]           # 1st row
df.iloc[4:7]         # 2st row row 4 to row 6 in indexing last index is exclusive





# Select row & columns / Cells

df.loc[0, "country"]    # 0th row & specific column
df.iloc[0, 2]           # 1st row & 3rd column (by position / indexing)


df.iloc[0, 1:5]
df.loc[0, ["country", "aqi"]]


df


df.loc[0:5, ["country","city","latitude"]]  # end is inclusive
df.iloc[0:5, 1:3]                           # end is exclusive


# Select single scalar value
df.at[0, "city"]
df.iat[0, 2]


df








# aqi is greater than 100
df[ df["aqi"] > 100]
# aqi is greather than 100 and temperature is greate 30 - combine two condition
df[ (df["aqi"] > 100)  & (df["temperature"] > 30) ] 

# get city and aqi column from sorted data - combine conditaion with pass columns name. outeside the condidion [] brecket. 
df[ (df["aqi"] > 100)  & (df["temperature"] > 30) ] [["city","aqi"] ] 










# query()

df.query("aqi > 100 & temperature > 30")

aqi_val = 100

df.query("aqi > @aqi_val & temperature > 30")[["country","city","aqi"]].copy()

# query() method is return copy of the data, but we don't need to remember wich method return copy and which is return view. 
# if we want to return copy of the data use directly ".copy()" method. 






