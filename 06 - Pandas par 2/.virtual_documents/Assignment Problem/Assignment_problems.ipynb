


import numpy as np
import pandas as pd


df_flower = pd.read_csv("IRIS.csv")



# Display the following information 
# 1. first 10 rows
# 2. shape & Data types
# 3. summary statistics (mean,std,max,min))


df2 = df_flower.copy()


# 1. fist 10 rows
df2.head(10)


# shape & Data types

df2.shape


df2.dtypes





# 3 summary statistics (mean,std,max,min))


df2.groupby("species")["sepal_length"].agg(avg_sepal_len_mean = "mean", avg_sepal_len_max = "max", avg_sepal_len_min = "min", avg_sepal_len_std = "std")


df2





# B- Select only those rows where:
# petal_length > 4.5
# species = "iris-virginica"


df_b = df_flower.copy()


# petal_length > 4.5
df_b.query("petal_length > 4.5")


# species = "iris-virginica"

virginica_only = df_b[df_b['species'] == "Iris-virginica"]
virginica_only





# Group by species and compute
# 1 Average sepal_length
# 2 Maximum petal_width
# 3 Standard deviation of sepal_width

df_b.groupby("species").agg(
    avg_sepal_len=("sepal_length", "mean"),
    max_petal_wid =("petal_width","max"),
    std_sepal_wid = ("petal_width","std")
)





# d create a new column "petal_ratio" = petal_length / petal_width
# for each species, find the averate petal_ratio


df_b["petal_ratio"] = df_b["petal_length"] / df_b["petal_width"]


df_b








df_titanic = pd.read_csv("Titanic-Dataset.csv")
