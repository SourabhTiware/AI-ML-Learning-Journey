df_c = df_titanic.copy()



# Group by Pclass and compute:
# Survival rate
# Averate Fare
# Average Age

df_c.groupby("Name").agg(
    survival_rate=("Survived", "mean"),
    average_fare=("Fare", "mean"),
    average_age=("Age", "mean")
)





